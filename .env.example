# ---- Required ----
# Your Anthropic API key (https://console.anthropic.com/ -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# ---- Optional ----
# Override the Claude model. Default: claude-opus-4-8 (most capable).
# For faster/cheaper responses during a live demo, use: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# HuggingFace token (free at https://huggingface.co/settings/tokens).
# Only needed for NLLB-200 translation via the HF Inference API.
# Without it, the app falls back to Claude for translation.
# HF_TOKEN=hf_...
